{
  "expo": {
    "name": "Spendly",
    "slug": "spendly-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/spendly_s_logo.png",
    "scheme": "spendly-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash_image.png",
      "resizeMode": "contain",
      "backgroundColor": "#030704"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.spendlyapp.personal"
    },
    "android": {
      "package": "com.spendlyapp.personal",
      "versionCode": 1,
      "jsEngine": "hermes",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/spendly_s_logo.png",
        "backgroundColor": "#030704"
      },
      "navigationBar": {
        "backgroundColor": "#030704",
        "barStyle": "light-content"
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/images/spendly_s_logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-build-properties",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/spendly_s_logo.png",
          "color": "#18633f",
          "defaultChannel": "expense-reminders",
          "sounds": []
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3859841618293423~8371426177"
        }
      ]
    ],
    "react-native-google-mobile-ads": {
      "android_app_id": "ca-app-pub-3859841618293423~8371426177",
      "androidAppId": "ca-app-pub-3859841618293423~8371426177"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
